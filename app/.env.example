# Backend notification settings
# Copy to app/.env (or export these in your shell) before running FastAPI.

# Enable notifications
EMAIL_NOTIFICATIONS_ENABLED=true

# Provider: "log" for local dev logs, "smtp" for real email
EMAIL_PROVIDER=log

# SMTP settings (used only when EMAIL_PROVIDER=smtp)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_FROM_EMAIL=forgeappfitness@gmail.com
SMTP_USERNAME=forgeappfitness@gmail.com
SMTP_PASSWORD=replace_with_app_password
SMTP_USE_TLS=true
